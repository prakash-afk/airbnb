<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home Added — Airbnb</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'DM Sans', sans-serif; }
        .brand { font-family: 'Pacifico', cursive; }

        .fade-up { animation: fadeUp 0.6s ease both; }
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: none; }
        }

        .pop {
            animation: pop 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) both;
        }
        @keyframes pop {
            from { opacity: 0; transform: scale(0.5); }
            to   { opacity: 1; transform: scale(1); }
        }

        .float {
            animation: floating 3s ease-in-out infinite;
        }
        @keyframes floating {
            0%, 100% { transform: translateY(0px); }
            50%       { transform: translateY(-10px); }
        }

        .btn {
            transition: transform 0.15s ease, box-shadow 0.2s ease;
        }
        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(244,63,94,0.35);
        }
        .btn:active { transform: scale(0.97); }

        .confetti {
            position: fixed;
            width: 10px;
            height: 10px;
            border-radius: 2px;
            animation: fall linear forwards;
        }
        @keyframes fall {
            0%   { transform: translateY(-20px) rotate(0deg); opacity: 1; }
            100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
        }
    </style>
</head>
<body class="bg-rose-50 min-h-screen flex flex-col">

    <%# Navbar %>
    <header class="bg-white border-b border-rose-100 sticky top-0 z-10 shadow-sm">
        <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
            <a href="/" class="brand text-rose-500 text-2xl">airbnb</a>
            <span class="text-sm text-gray-400">Hosting</span>
        </div>
    </header>

    <%# Success Content %>
    <main class="flex-1 flex items-center justify-center px-4 py-16">
        <div class="w-full max-w-md">

            <div class="bg-white rounded-3xl border border-rose-100 shadow-xl overflow-hidden">

                <%# Success Banner %>
                <div class="bg-gradient-to-r from-rose-400 to-orange-300 px-8 py-8 relative overflow-hidden text-center">
                    <div class="absolute -top-6 -right-6 w-28 h-28 bg-white/10 rounded-full"></div>
                    <div class="absolute -bottom-8 -left-4 w-20 h-20 bg-white/10 rounded-full"></div>

                    <%# Checkmark circle %>
                    <div class="pop relative z-10 w-16 h-16 bg-white rounded-full flex items-center justify-center mx-auto mb-4 shadow-md">
                        <svg class="w-8 h-8 text-rose-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                        </svg>
                    </div>

                    <h1 class="text-white text-2xl font-semibold relative z-10">You're a Host!</h1>
                    <p class="text-white/70 text-sm mt-1 relative z-10">Your home has been listed successfully</p>
                </div>

                <%# Details %>
                <div class="px-8 py-8 space-y-6">

                    <%# Home name display %>
                    <% if (typeof houseName !== 'undefined' && houseName) { %>
                        <div class="fade-up bg-rose-50 rounded-2xl px-5 py-4 border border-rose-100 flex items-center gap-4" style="animation-delay: 0.1s">
                            <div class="float text-3xl">🏠</div>
                            <div>
                                <p class="text-xs text-gray-400 mb-0.5">Registered as</p>
                                <p class="text-gray-800 font-semibold text-base"><%= houseName %></p>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="fade-up text-center" style="animation-delay: 0.1s">
                            <div class="float text-5xl mb-2">🏠</div>
                        </div>
                    <% } %>

                    <%# What's next checklist %>
                    <div class="fade-up space-y-3" style="animation-delay: 0.2s">
                        <p class="text-sm font-medium text-gray-600">What's next?</p>
                        <% const steps = [
                            { icon: '📸', text: 'Add photos of your home' },
                            { icon: '💰', text: 'Set your nightly price' },
                            { icon: '📅', text: 'Update your availability' }
                        ] %>
                        <% steps.forEach((step, i) => { %>
                            <div class="flex items-center gap-3 bg-gray-50 rounded-xl px-4 py-3 border border-gray-100">
                                <span class="text-lg"><%= step.icon %></span>
                                <span class="text-sm text-gray-500"><%= step.text %></span>
                                <span class="ml-auto text-xs text-gray-300">Soon</span>
                            </div>
                        <% }) %>
                    </div>

                    <%# Action Buttons %>
                    <div class="fade-up flex flex-col gap-3 pt-2" style="animation-delay: 0.3s">
                        <a href="/"
                           class="btn bg-rose-500 hover:bg-rose-600 text-white font-medium px-6 py-3 rounded-xl text-sm text-center shadow-md">
                            View All Listings
                        </a>
                        <a href="/host/add-home"
                           class="btn bg-white hover:bg-rose-50 text-rose-500 font-medium px-6 py-3 rounded-xl text-sm text-center border border-rose-200">
                            + Add Another Home
                        </a>
                    </div>

                </div>
            </div>

            <p class="text-center text-xs text-gray-300 mt-6 fade-up" style="animation-delay: 0.4s">
                Thank you for hosting with airbnb 🌍
            </p>

        </div>
    </main>

    <%# Confetti script %>
    <script>
        const colors = ['#f43f5e','#fb923c','#fbbf24','#34d399','#60a5fa','#a78bfa'];
        for (let i = 0; i < 60; i++) {
            const el = document.createElement('div');
            el.className = 'confetti';
            el.style.cssText = `
                left: ${Math.random() * 100}vw;
                background: ${colors[Math.floor(Math.random() * colors.length)]};
                width: ${6 + Math.random() * 8}px;
                height: ${6 + Math.random() * 8}px;
                animation-duration: ${1.5 + Math.random() * 2}s;
                animation-delay: ${Math.random() * 1.5}s;
                border-radius: ${Math.random() > 0.5 ? '50%' : '2px'};
            `;
            document.body.appendChild(el);
            el.addEventListener('animationend', () => el.remove());
        }
    </script>

</body>
</html>
