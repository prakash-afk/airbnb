<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %> - Airbnb</title>
    <link rel="stylesheet" href="/output.css">
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'DM Sans', sans-serif; }
        .brand { font-family: 'Pacifico', cursive; }
        .scene {
            background:
                radial-gradient(circle at 10% 20%, rgba(59, 130, 246, 0.14), transparent 24rem),
                radial-gradient(circle at 88% 15%, rgba(244, 63, 94, 0.14), transparent 22rem),
                linear-gradient(135deg, #fefbf8 0%, #fff6f0 45%, #fff9fd 100%);
        }
        .shell {
            animation: rise 0.75s cubic-bezier(.2,.8,.2,1) both;
        }
        .glass {
            backdrop-filter: blur(12px);
            background: rgba(255,255,255,0.86);
            box-shadow: 0 26px 58px rgba(15, 23, 42, 0.12), 0 12px 26px rgba(244, 63, 94, 0.1);
        }
        .field:focus {
            outline: none;
            border-color: #f43f5e;
            box-shadow: 0 0 0 4px rgba(244, 63, 94, 0.12);
        }
        .type-card {
            transition: transform 0.16s ease, border-color 0.2s ease, background-color 0.2s ease;
        }
        .type-card:hover { transform: translateY(-2px); }
        .type-card.active {
            border-color: #fb7185;
            background: rgba(255, 241, 242, 0.9);
            color: #e11d48;
        }
        .signup-btn {
            transition: transform 0.18s ease, box-shadow 0.22s ease;
        }
        .signup-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 16px 28px rgba(244, 63, 94, 0.25);
        }
        @keyframes rise {
            from { opacity: 0; transform: translateY(24px) scale(0.98); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
    </style>
</head>
<body class="scene min-h-screen">
    <header>
        <div class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
            <a href="/" class="brand text-rose-500 text-2xl">airbnb</a>
            <div class="flex items-center gap-4 text-sm">
                <a href="/" class="text-gray-500 hover:text-rose-500">Back to listings</a>
                <a href="/login" class="text-gray-500 hover:text-rose-500">Login</a>
            </div>
        </div>
    </header>

    <main class="max-w-6xl mx-auto px-6 py-10 min-h-[calc(100vh-5rem)] flex items-center">
        <div class="grid grid-cols-1 lg:grid-cols-[0.95fr_1.05fr] gap-10 items-center w-full">
            <section class="space-y-5">
                <p class="text-sm uppercase tracking-[0.24em] text-rose-400 font-semibold">Join Airbnb</p>
                <h1 class="text-5xl md:text-6xl font-semibold text-gray-900 leading-[1.05]">
                    Create your account and make favourites
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-rose-500 to-orange-400">truly yours</span>
                </h1>
                <p class="text-lg text-gray-500 max-w-xl leading-8">
                    Sign up as a guest or host. Your favourites, session, and access level will now belong to your account instead of being shared globally.
                </p>
            </section>

            <section class="shell">
                <div class="glass rounded-[2rem] border border-white/80 p-8 md:p-9">
                    <div class="mb-7">
                        <p class="text-sm text-rose-400 font-medium mb-1">Account setup</p>
                        <h2 class="text-3xl font-semibold text-gray-900">Sign up</h2>
                    </div>

                    <% if (errors && errors.length) { %>
                        <div class="mb-5 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-4 text-sm text-rose-600">
                            <ul class="space-y-1">
                                <% errors.forEach(error => { %>
                                    <li><%= error %></li>
                                <% }) %>
                            </ul>
                        </div>
                    <% } %>

                    <form action="/signup" method="post" class="space-y-5">
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-600 mb-2">First name</label>
                                <input type="text" name="firstName" value="<%= oldInput.firstName %>" class="field w-full rounded-2xl border border-gray-200 bg-white/90 px-4 py-3.5 text-sm text-gray-800" required>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-600 mb-2">Last name</label>
                                <input type="text" name="lastName" value="<%= oldInput.lastName %>" class="field w-full rounded-2xl border border-gray-200 bg-white/90 px-4 py-3.5 text-sm text-gray-800" required>
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-600 mb-2">Email</label>
                            <input type="email" name="email" value="<%= oldInput.email %>" class="field w-full rounded-2xl border border-gray-200 bg-white/90 px-4 py-3.5 text-sm text-gray-800" required>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-600 mb-2">Password</label>
                                <input type="password" name="password" class="field w-full rounded-2xl border border-gray-200 bg-white/90 px-4 py-3.5 text-sm text-gray-800" required>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-600 mb-2">Confirm password</label>
                                <input type="password" name="confirmPassword" class="field w-full rounded-2xl border border-gray-200 bg-white/90 px-4 py-3.5 text-sm text-gray-800" required>
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-600 mb-2">I am joining as</label>
                            <div class="grid grid-cols-2 gap-3">
                                <button type="button" class="type-card <%= oldInput.userType === 'guest' ? 'active' : '' %> rounded-2xl border border-gray-200 px-4 py-4 text-left" data-user-type="guest">
                                    <span class="block text-2xl mb-2">🧳</span>
                                    <span class="block text-sm font-semibold">Guest</span>
                                    <span class="block text-xs text-gray-500 mt-1">Save favourites and explore stays.</span>
                                </button>
                                <button type="button" class="type-card <%= oldInput.userType === 'host' ? 'active' : '' %> rounded-2xl border border-gray-200 px-4 py-4 text-left" data-user-type="host">
                                    <span class="block text-2xl mb-2">🏠</span>
                                    <span class="block text-sm font-semibold">Host</span>
                                    <span class="block text-xs text-gray-500 mt-1">Manage and publish your listings.</span>
                                </button>
                            </div>
                            <input type="hidden" name="userType" id="userTypeInput" value="<%= oldInput.userType %>">
                        </div>

                        <label class="flex items-start gap-3 rounded-2xl border border-gray-200 bg-white/70 px-4 py-4 text-sm text-gray-600">
                            <input type="checkbox" name="terms" <%= oldInput.terms ? 'checked' : '' %> class="mt-1 accent-rose-500">
                            <span>I agree to the hosting and guest terms, privacy practices, and session-based account access.</span>
                        </label>

                        <button type="submit" class="signup-btn w-full bg-gradient-to-r from-rose-500 to-orange-400 text-white font-semibold py-3.5 rounded-2xl text-sm">
                            Create Account
                        </button>
                    </form>
                </div>
            </section>
        </div>
    </main>

    <script>
        const userTypeInput = document.getElementById('userTypeInput');
        const typeButtons = document.querySelectorAll('[data-user-type]');

        typeButtons.forEach((button) => {
            button.addEventListener('click', () => {
                typeButtons.forEach((item) => item.classList.remove('active'));
                button.classList.add('active');
                userTypeInput.value = button.dataset.userType;
            });
        });
    </script>
</body>
</html>
