<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle || 'Server Error' %></title>
    <link rel="stylesheet" href="/output.css">
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'DM Sans', sans-serif; }
        .brand { font-family: 'Pacifico', cursive; }
    </style>
</head>
<body class="bg-rose-50 min-h-screen flex flex-col">
    <header class="bg-white border-b border-rose-100 sticky top-0 z-10 shadow-sm">
        <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
            <a href="/" class="brand text-rose-500 text-2xl">airbnb</a>
            <a href="/" class="text-sm text-gray-400 hover:text-rose-400 transition-colors">Back to listings</a>
        </div>
    </header>

    <main class="flex-1 flex items-center justify-center px-4 py-16">
        <div class="w-full max-w-lg bg-white rounded-3xl border border-rose-100 shadow-xl p-8 text-center">
            <p class="text-sm font-medium text-rose-400 mb-3">Server Error</p>
            <h1 class="text-3xl font-semibold text-gray-800 mb-3">We couldn't finish that request</h1>
            <p class="text-gray-500 text-sm mb-6"><%= errorMessage %></p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
                <a href="/" class="bg-rose-500 hover:bg-rose-600 text-white font-medium px-6 py-3 rounded-xl text-sm text-center shadow-md">
                    Go to Home
                </a>
                <a href="/host/add-home" class="bg-white hover:bg-rose-50 text-rose-500 font-medium px-6 py-3 rounded-xl text-sm text-center border border-rose-200">
                    Try Adding Again
                </a>
            </div>
        </div>
    </main>
</body>
</html>
