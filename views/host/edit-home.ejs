<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit <%= home.houseName %></title>
    <link rel="stylesheet" href="/output.css">
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'DM Sans', sans-serif; }
        .brand { font-family: 'Pacifico', cursive; }
        .input-field { transition: border-color 0.2s, box-shadow 0.2s; }
        .input-field:focus {
            outline: none;
            border-color: #f43f5e;
            box-shadow: 0 0 0 4px rgba(244, 63, 94, 0.12);
        }
        .field-warning {
            min-height: 1.25rem;
        }
    </style>
</head>
<body class="bg-rose-50 min-h-screen">
    <% const formData = typeof oldInput !== 'undefined' ? oldInput : home; %>
    <header class="bg-white border-b border-rose-100 shadow-sm">
        <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
            <a href="/" class="brand text-rose-500 text-2xl">airbnb</a>
            <div class="flex gap-4 text-sm">
                <a href="/host/homes" class="text-gray-400 hover:text-rose-500">Host Homes</a>
                <a href="/homes/<%= home.id %>" class="text-gray-400 hover:text-rose-500">Open Detail</a>
            </div>
        </div>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-10">
        <div class="bg-white rounded-3xl border border-rose-100 shadow-xl overflow-hidden">
            <div class="bg-gradient-to-r from-rose-400 to-orange-300 px-8 py-6">
                <p class="text-white/80 text-sm font-medium mb-1">Host Edit View</p>
                <h1 class="text-white text-3xl font-semibold">Edit <%= home.houseName %></h1>
                <p class="text-white/70 text-sm mt-1">Update listing details and save them back to your store.</p>
            </div>

            <form action="/host/edit-home/<%= home.id %>" method="post" class="px-8 py-8 space-y-5">
                <% if (errors && errors.length > 0) { %>
                    <div class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-4 text-sm text-rose-600">
                        <p class="font-semibold mb-2">Please fix these issues before saving:</p>
                        <ul class="list-disc pl-5 space-y-1">
                            <% errors.forEach(error => { %>
                                <li><%= error %></li>
                            <% }) %>
                        </ul>
                    </div>
                <% } %>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div>
                        <label class="block text-sm font-medium text-gray-600 mb-1.5">Home Name</label>
                        <input type="text" name="houseName" id="houseName" required maxlength="60" value="<%= formData.houseName %>" class="input-field w-full border border-gray-200 rounded-xl px-4 py-3 text-sm bg-rose-50/30">
                        <p id="houseNameWarning" class="field-warning mt-1 text-xs text-amber-600"></p>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-600 mb-1.5">Location</label>
                        <input type="text" name="location" id="location" required value="<%= formData.location %>" class="input-field w-full border border-gray-200 rounded-xl px-4 py-3 text-sm bg-rose-50/30">
                        <p id="locationWarning" class="field-warning mt-1 text-xs text-amber-600"></p>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-600 mb-1.5">Price per Night</label>
                        <input type="number" name="price" min="1" step="1" required value="<%= formData.price %>" class="input-field w-full border border-gray-200 rounded-xl px-4 py-3 text-sm bg-rose-50/30">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-600 mb-1.5">Photo URL</label>
                        <input type="url" name="photo" value="<%= formData.photo %>" class="input-field w-full border border-gray-200 rounded-xl px-4 py-3 text-sm bg-rose-50/30">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-600 mb-1.5">Rating</label>
                        <input type="number" name="rating" min="0" max="5" step="1" value="<%= formData.rating %>" class="input-field w-full border border-gray-200 rounded-xl px-4 py-3 text-sm bg-rose-50/30">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-600 mb-1.5">Max Guests</label>
                        <input type="number" name="maxGuests" min="1" max="20" step="1" value="<%= formData.maxGuests %>" class="input-field w-full border border-gray-200 rounded-xl px-4 py-3 text-sm bg-rose-50/30">
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-600 mb-2">Home Type</label>
                    <select name="homeType" class="input-field w-full border border-gray-200 rounded-xl px-4 py-3 text-sm bg-rose-50/30">
                        <option value="">Select a type</option>
                        <% ['House', 'Apartment', 'Cabin', 'Beach House', 'Farm', 'Villa'].forEach(type => { %>
                            <option value="<%= type %>" <%= formData.homeType === type ? 'selected' : '' %>><%= type %></option>
                        <% }) %>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-600 mb-2">Availability</label>
                    <div class="grid grid-cols-2 gap-3">
                        <label class="flex items-center gap-3 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-gray-700">
                            <input type="radio" name="availability" value="available" <%= formData.availability !== 'unavailable' ? 'checked' : '' %> class="accent-rose-500">
                            <span>Available for booking</span>
                        </label>
                        <label class="flex items-center gap-3 rounded-xl border border-gray-200 bg-white px-4 py-3 text-sm text-gray-700">
                            <input type="radio" name="availability" value="unavailable" <%= formData.availability === 'unavailable' ? 'checked' : '' %> class="accent-rose-500">
                            <span>Not available right now</span>
                        </label>
                    </div>
                </div>

                <div class="flex flex-col sm:flex-row gap-3 pt-2">
                    <button type="submit" class="bg-rose-500 hover:bg-rose-600 text-white font-semibold px-6 py-3 rounded-xl text-sm shadow-md">
                        Save Changes
                    </button>
                    <a href="/host/homes" class="bg-white hover:bg-rose-50 text-rose-500 font-medium px-6 py-3 rounded-xl text-sm text-center border border-rose-200">
                        Cancel
                    </a>
                </div>
            </form>

            <div class="px-8 pb-8">
                <div class="rounded-2xl border border-rose-100 bg-rose-50/60 px-5 py-5">
                    <p class="text-sm font-semibold text-gray-700 mb-1">Delete this listing</p>
                    <p class="text-sm text-gray-500 mb-4">Remove this home from your host dashboard, listing pages, favourites, and details view.</p>
                    <form action="/host/delete-home/<%= home.id %>" method="post" onsubmit="return confirm('Delete <%= home.houseName %>? This action cannot be undone.');">
                        <button type="submit" class="bg-white hover:bg-rose-100 text-rose-600 font-semibold px-5 py-3 rounded-xl text-sm border border-rose-200">
                            Delete Home
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </main>

    <script>
        const textPattern = /^(?=.*[A-Za-z])[A-Za-z0-9\\s,.'-]+$/;
        const houseNameInput = document.getElementById('houseName');
        const locationInput = document.getElementById('location');
        const houseNameWarning = document.getElementById('houseNameWarning');
        const locationWarning = document.getElementById('locationWarning');

        function validateTextField(input, warningElement, message) {
            const value = input.value.trim();
            if (!value) {
                warningElement.textContent = '';
                input.classList.remove('border-amber-400', 'bg-amber-50/40');
                return;
            }

            const isValid = textPattern.test(value);
            warningElement.textContent = isValid ? '' : message;
            input.classList.toggle('border-amber-400', !isValid);
            input.classList.toggle('bg-amber-50/40', !isValid);
        }

        houseNameInput.addEventListener('input', () => {
            validateTextField(houseNameInput, houseNameWarning, 'Use a real home name, not only numbers or symbols.');
        });

        locationInput.addEventListener('input', () => {
            validateTextField(locationInput, locationWarning, 'Use a real location name, not only numbers or symbols.');
        });

        validateTextField(houseNameInput, houseNameWarning, 'Use a real home name, not only numbers or symbols.');
        validateTextField(locationInput, locationWarning, 'Use a real location name, not only numbers or symbols.');
    </script>
</body>
</html>
