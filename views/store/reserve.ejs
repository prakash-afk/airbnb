<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reserve <%= home.houseName %></title>
    <link rel="stylesheet" href="/output.css">
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <style>body{font-family:'DM Sans',sans-serif}.brand{font-family:'Pacifico',cursive}</style>
</head>
<body class="bg-rose-50 min-h-screen">
    <header class="bg-white border-b border-rose-100 shadow-sm">
        <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
            <a href="/" class="brand text-rose-500 text-2xl">airbnb</a>
            <div class="flex items-center gap-4 text-sm">
                <a href="/homes/<%= home.id %>" class="text-gray-400 hover:text-rose-500">Back to detail</a>
                <% if (isLoggedIn) { %>
                    <span class="inline-flex items-center rounded-full bg-rose-50 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-rose-500">
                        <%= currentUser ? currentUser.userType : 'Guest' %>
                    </span>
                    <form action="/logout" method="post">
                        <button type="submit" class="text-gray-400 hover:text-rose-500">Logout</button>
                    </form>
                <% } else { %>
                    <a href="/login" class="text-gray-400 hover:text-rose-500">Login</a>
                <% } %>
            </div>
        </div>
    </header>
    <%- include('../partials/flash') %>
    <main class="max-w-3xl mx-auto px-6 py-10">
        <div class="bg-white rounded-3xl border border-rose-100 shadow-xl p-8">
            <p class="text-sm text-rose-400 font-medium mb-2">Reserve View</p>
            <h1 class="text-3xl font-semibold text-gray-800 mb-3">Reserve <%= home.houseName %></h1>
            <p class="text-gray-500 mb-6">This store page is ready for future booking form logic.</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="rounded-2xl bg-rose-50 px-4 py-3">
                    <p class="text-gray-400 text-sm">Location</p>
                    <p class="text-gray-800 font-medium"><%= home.location %></p>
                </div>
                <div class="rounded-2xl bg-rose-50 px-4 py-3">
                    <p class="text-gray-400 text-sm">Price</p>
                    <p class="text-gray-800 font-medium"><%= home.price ? `Rs ${home.price} / night` : 'Not set' %></p>
                </div>
            </div>
        </div>
    </main>
</body>
</html>
