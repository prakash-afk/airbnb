<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bookings</title>
    <link rel="stylesheet" href="/output.css">
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <style>body{font-family:'DM Sans',sans-serif}.brand{font-family:'Pacifico',cursive}</style>
</head>
<body class="bg-rose-50 min-h-screen">
    <header class="bg-white border-b border-rose-100 shadow-sm">
        <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
            <a href="/" class="brand text-rose-500 text-2xl">airbnb</a>
            <div class="flex items-center gap-4 text-sm">
                <a href="/" class="text-gray-400 hover:text-rose-500">Back to listings</a>
                <% if (isLoggedIn) { %>
                    <span class="inline-flex items-center rounded-full bg-rose-50 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-rose-500">
                        Guest
                    </span>
                    <form action="/logout" method="post">
                        <button type="submit" class="text-gray-400 hover:text-rose-500">Logout</button>
                    </form>
                <% } else { %>
                    <a href="/login" class="text-gray-400 hover:text-rose-500">Login</a>
                <% } %>
            </div>
        </div>
    </header>
    <%- include('../partials/flash') %>
    <main class="max-w-5xl mx-auto px-6 py-10">
        <h1 class="text-3xl font-semibold text-gray-800 mb-2">Bookings</h1>
        <p class="text-gray-400 mb-8">A guest-facing bookings area for upcoming and future reservation records.</p>
        <div class="space-y-4">
            <% if (!homes.length) { %>
                <div class="bg-white rounded-3xl border border-rose-100 p-6 text-gray-500">No bookings to show yet.</div>
            <% } else { %>
                <% homes.forEach(home => { %>
                    <div class="bg-white rounded-3xl border border-rose-100 p-5 flex items-center justify-between gap-4">
                        <div>
                            <p class="text-sm text-rose-400 mb-1"><%= home.homeType || 'Stay' %></p>
                            <h2 class="text-xl font-semibold text-gray-800"><%= home.houseName %></h2>
                            <p class="text-gray-400"><%= home.location %></p>
                        </div>
                        <a href="/reserve/<%= home.id %>" class="text-sm bg-rose-500 hover:bg-rose-600 text-white px-4 py-2 rounded-xl">Open reserve</a>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </main>
</body>
</html>
