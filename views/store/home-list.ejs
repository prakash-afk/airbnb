<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Airbnb — Listings</title>
    <link rel="stylesheet" href="/output.css">
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'DM Sans', sans-serif; }
        .brand { font-family: 'Pacifico', cursive; }
        .card {
            perspective: 1200px;
        }
        .card-clickable {
            cursor: pointer;
        }
        .card-inner {
            position: relative;
            transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
            will-change: transform, box-shadow;
        }
        .card-inner::before {
            content: "";
            position: absolute;
            inset: -1px;
            border-radius: 1rem;
            background: linear-gradient(135deg, rgba(244, 63, 94, 0.55), rgba(251, 146, 60, 0.45), rgba(244, 63, 94, 0.3));
            opacity: 0;
            filter: blur(14px);
            transition: opacity 0.35s ease;
            z-index: -1;
        }
        .card:hover .card-inner {
            transform: translateY(-14px) scale(1.02);
            border-color: rgba(251, 113, 133, 0.55);
            box-shadow: 0 24px 50px rgba(244, 63, 94, 0.18), 0 18px 28px rgba(15, 23, 42, 0.12);
        }
        .card:hover .card-inner::before {
            opacity: 1;
        }
        .card:hover img {
            transform: scale(1.05);
        }
        .fade-in { animation: fadeIn 0.5s ease both; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: none; } }
        .wishlist-btn { transition: transform 0.22s ease, background-color 0.22s ease, box-shadow 0.22s ease; }
        .wishlist-btn:hover {
            transform: scale(1.16);
            background-color: rgba(255,255,255,0.98);
            box-shadow: 0 10px 18px rgba(244, 63, 94, 0.16);
        }
        .wishlist-btn.active { color: #f43f5e; }
        .card-media img {
            transition: transform 0.45s ease;
        }
        .card-focus-ring:focus-visible {
            outline: 3px solid rgba(244, 63, 94, 0.4);
            outline-offset: 4px;
        }
    </style>
</head>
<body class="bg-rose-50 min-h-screen flex flex-col">

    <%# Navbar with active tab %>
    <header class="bg-white border-b border-rose-100 sticky top-0 z-10 shadow-sm">
        <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
            <span class="brand text-rose-500 text-2xl">airbnb</span>
            <nav class="flex items-center gap-6 text-sm flex-wrap justify-end">
                <a href="/" class="text-rose-500 font-semibold border-b-2 border-rose-500 pb-0.5">Listings</a>
                <% if (!(currentUser && currentUser.userType === 'host')) { %>
                    <a href="/favourites" class="text-gray-400 hover:text-rose-500 transition-colors pb-0.5">Favourites</a>
                    <a href="/bookings" class="text-gray-400 hover:text-rose-500 transition-colors pb-0.5">Bookings</a>
                <% } %>
                <% if (currentUser && currentUser.userType === 'host') { %>
                    <a href="/host/homes" class="text-gray-400 hover:text-rose-500 transition-colors pb-0.5">Host Homes</a>
                    <a href="/host/add-home" class="text-gray-400 hover:text-rose-500 transition-colors pb-0.5">Add Home</a>
                <% } %>
                <% if (isLoggedIn) { %>
                    <span class="inline-flex items-center rounded-full bg-rose-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-rose-500">
                        <%= currentUser.userType %>
                    </span>
                    <form action="/logout" method="post">
                        <button type="submit" class="text-gray-400 hover:text-rose-500 transition-colors pb-0.5">Logout</button>
                    </form>
                <% } else { %>
                    <a href="/login" class="bg-rose-500 hover:bg-rose-600 text-white px-4 py-2 rounded-full transition-colors shadow-sm">Login</a>
                    <a href="/signup" class="text-gray-400 hover:text-rose-500 transition-colors pb-0.5">Sign Up</a>
                <% } %>
            </nav>
        </div>
    </header>

    <%- include('../partials/flash') %>

    <% const isHostUser = currentUser && currentUser.userType === 'host'; %>
    <% const isGuestUser = currentUser && currentUser.userType === 'guest'; %>

    <%# Hero %>
    <section class="max-w-5xl mx-auto px-6 pt-10 pb-4 fade-in">
        <h1 class="text-4xl font-semibold text-gray-800 leading-tight">
            Find your next <span class="text-rose-500">stay</span>
        </h1>
        <p class="text-gray-400 mt-1 text-base">Browse homes registered by our hosts</p>
    </section>

    <main class="max-w-5xl mx-auto px-6 pb-16 w-full">

        <% if (registerHome.length === 0) { %>
            <%# Empty State %>
            <div class="flex flex-col items-center justify-center py-24 text-center fade-in">
                <div class="text-6xl mb-4">🏠</div>
                <% if (isGuestUser) { %>
                    <h2 class="text-xl font-semibold text-gray-700">No stays are available right now</h2>
                    <p class="text-gray-400 mt-1 text-sm max-w-md">
                        Sorry for the inconvenience. There are no homes available to book at the moment.
                    </p>
                    <p class="text-gray-400 mt-2 text-sm max-w-md">
                        Please check back soon for new listings from our hosts.
                    </p>
                <% } else { %>
                    <h2 class="text-xl font-semibold text-gray-700">No homes listed yet</h2>
                    <p class="text-gray-400 mt-1 mb-6 text-sm">
                        <%= isHostUser ? 'Be the first to add your home!' : 'Sorry for the inconvenience. There are no stays available yet.' %>
                    </p>
                <% } %>
                <% if (isHostUser) { %>
                    <a href="/host/add-home"
                       class="bg-rose-500 hover:bg-rose-600 text-white text-sm font-medium px-6 py-2.5 rounded-full transition-all duration-200 shadow">
                        Add a Home
                    </a>
                <% } %>
            </div>

        <% } else { %>

            <%# Count + Add button row %>
            <div class="flex items-center justify-between mb-6">
                <p class="text-sm text-gray-400">
                    <span class="font-semibold text-gray-600"><%= registerHome.length %></span>
                    home listing<%= registerHome.length !== 1 ? 's' : '' %>
                </p>
                <% if (currentUser && currentUser.userType === 'host') { %>
                    <a href="/host/add-home"
                       class="bg-rose-500 hover:bg-rose-600 text-white text-xs font-medium px-4 py-2 rounded-full transition-all shadow">
                        + Add Home
                    </a>
                <% } else if (!isLoggedIn) { %>
                    <a href="/signup"
                       class="bg-rose-500 hover:bg-rose-600 text-white text-xs font-medium px-4 py-2 rounded-full transition-all shadow">
                        + Sign Up
                    </a>
                <% } %>
            </div>

            <%# Cards Grid %>
            <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                <% registerHome.forEach((home, index) => { %>
                    <li class="card fade-in" style="animation-delay: <%= index * 60 %>ms">
                        <div
                            class="card-inner card-clickable card-focus-ring bg-white rounded-2xl overflow-hidden border border-rose-100 shadow-sm"
                            data-card-link="/homes/<%= home.id %>"
                            tabindex="0"
                            role="link"
                            aria-label="Open details for <%= home.houseName %>"
                        >

                            <%# Photo %>
                            <div class="card-media relative h-48 bg-gradient-to-br from-rose-100 to-orange-100 overflow-hidden">
                                <% if (home.photo) { %>
                                    <img src="<%= home.photo %>" alt="<%= home.houseName %>"
                                        class="w-full h-full object-cover"
                                        onerror="this.style.display='none'">
                                <% } else { %>
                                    <div class="w-full h-full flex items-center justify-center text-5xl">🏡</div>
                                <% } %>

                                <%# Home type badge %>
                                <% if (home.homeType) { %>
                                    <span class="absolute top-3 left-3 bg-white/90 text-gray-600 text-xs font-medium px-2.5 py-1 rounded-full shadow-sm">
                                        <%= home.homeType %>
                                    </span>
                                <% } %>

                                <% if (!isHostUser) { %>
                                    <%# Wishlist button %>
                                    <button
                                        class="wishlist-btn absolute top-3 right-3 text-gray-300 text-xl bg-white/90 w-8 h-8 rounded-full flex items-center justify-center shadow-sm <%= home.isFavourite ? 'active' : '' %>"
                                        data-home-id="<%= home.id %>"
                                        data-is-favourite="<%= home.isFavourite ? 'true' : 'false' %>"
                                        aria-label="Toggle favourite"
                                    >
                                        <%= home.isFavourite ? '♥' : '♡' %>
                                    </button>
                                <% } %>
                            </div>

                            <%# Info %>
                            <div class="p-4">

                                <%# Name + Rating row %>
                                <div class="flex items-start justify-between gap-2 mb-1">
                                    <h3 class="font-semibold text-gray-800 text-base leading-tight line-clamp-1">
                                        <%= home.houseName %>
                                    </h3>
                                    <% if (home.reviewCount > 0) { %>
                                        <span class="flex items-center gap-0.5 text-sm text-gray-700 shrink-0">
                                            <span class="text-rose-400">★</span>
                                            <%= home.rating %>
                                            <span class="text-gray-400 text-xs">(<%= home.reviewCount %>)</span>
                                        </span>
                                    <% } %>
                                </div>

                                <%# Location %>
                                <% if (home.location) { %>
                                    <p class="text-gray-400 text-xs mb-3 flex items-center gap-1">
                                        <span>📍</span> <%= home.location %>
                                    </p>
                                <% } else { %>
                                    <p class="text-gray-400 text-xs mb-3">Registered property</p>
                                <% } %>

                                <%# Guests %>
                                <% if (home.maxGuests) { %>
                                    <p class="text-gray-400 text-xs mb-3">👥 Up to <%= home.maxGuests %> guests</p>
                                <% } %>

                                <%# Divider %>
                                <div class="border-t border-gray-100 pt-3 flex items-center justify-between">
                                    <% if (home.price) { %>
                                        <p class="text-gray-800 text-sm">
                                            <span class="font-semibold text-base">₹<%= home.price %></span>
                                            <span class="text-gray-400 text-xs"> / night</span>
                                        </p>
                                    <% } else { %>
                                        <p class="text-gray-400 text-xs">Price not set</p>
                                    <% } %>
                                    <span class="<%= home.availability === 'available' ? 'bg-rose-50 text-rose-400' : 'bg-gray-100 text-gray-500' %> text-xs px-2.5 py-1 rounded-full">
                                        <%= home.availability === 'available' ? 'Available' : 'Unavailable' %>
                                    </span>
                                </div>

                                <div class="mt-4 flex gap-2">
                                    <a href="/homes/<%= home.id %>"
                                       class="flex-1 bg-white hover:bg-rose-50 text-rose-500 text-xs font-medium px-3 py-2 rounded-xl text-center border border-rose-200 transition-all">
                                        Details
                                    </a>
                                    <% if (!isHostUser) { %>
                                        <a href="/reserve/<%= home.id %>"
                                           class="flex-1 bg-rose-500 hover:bg-rose-600 text-white text-xs font-medium px-3 py-2 rounded-xl text-center transition-all">
                                            Reserve
                                        </a>
                                    <% } %>
                                </div>

                            </div>
                        </div>
                    </li>
                <% }) %>
            </ul>

        <% } %>
    </main>

    <script>
        // Wishlist toggle
        document.querySelectorAll('[data-card-link]').forEach(card => {
            const openCard = () => {
                window.location.href = card.dataset.cardLink;
            };

            card.addEventListener('click', (event) => {
                if (event.target.closest('a, button')) {
                    return;
                }
                openCard();
            });

            card.addEventListener('keydown', (event) => {
                if (event.key === 'Enter' || event.key === ' ') {
                    event.preventDefault();
                    openCard();
                }
            });
        });

        document.querySelectorAll('.wishlist-btn').forEach(btn => {
            btn.addEventListener('click', async () => {
                const currentState = btn.dataset.isFavourite === 'true';
                const nextState = !currentState;
                const homeId = btn.dataset.homeId;

                try {
                    const response = await fetch(`/favourites/${homeId}`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({ isFavourite: nextState }),
                    });

                    if (!response.ok) {
                        if (response.status === 401) {
                            const result = await response.json();
                            window.location.href = result.redirectTo || '/login';
                            return;
                        }
                        throw new Error('Could not update favourite status.');
                    }

                    btn.dataset.isFavourite = String(nextState);
                    btn.classList.toggle('active', nextState);
                    btn.textContent = nextState ? '♥' : '♡';
                } catch (error) {
                    alert('Could not update favourite. Please try again.');
                }
            });
        });
    </script>

</body>
</html>
