<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= home.houseName %> - Details</title>
    <link rel="stylesheet" href="/output.css">
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'DM Sans', sans-serif; }
        .brand { font-family: 'Pacifico', cursive; }
        .gallery-tile {
            min-height: 9rem;
        }
        .wishlist-btn {
            transition: transform 0.22s ease, background-color 0.22s ease, box-shadow 0.22s ease;
        }
        .wishlist-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 18px rgba(244, 63, 94, 0.16);
        }
        .wishlist-btn.active {
            color: #f43f5e;
            border-color: rgba(251, 113, 133, 0.35);
            background-color: rgba(255, 241, 242, 0.95);
        }
    </style>
</head>
<body class="bg-rose-50 min-h-screen">
    <% const isHostUser = currentUser && currentUser.userType === 'host'; %>
    <header class="bg-white border-b border-rose-100 shadow-sm">
        <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
            <a href="/" class="brand text-rose-500 text-2xl">airbnb</a>
            <nav class="flex gap-5 text-sm">
                <a href="/" class="text-gray-400 hover:text-rose-500">Listings</a>
                <a href="/favourites" class="text-gray-400 hover:text-rose-500">Favourites</a>
                <a href="/bookings" class="text-gray-400 hover:text-rose-500">Bookings</a>
                <% if (isLoggedIn) { %>
                    <form action="/logout" method="post">
                        <button type="submit" class="text-gray-400 hover:text-rose-500">Logout</button>
                    </form>
                <% } else { %>
                    <a href="/login" class="text-gray-400 hover:text-rose-500">Login</a>
                    <a href="/signup" class="text-gray-400 hover:text-rose-500">Sign Up</a>
                <% } %>
            </nav>
        </div>
    </header>

    <main class="max-w-6xl mx-auto px-6 py-10">
        <section class="grid grid-cols-1 lg:grid-cols-[1.5fr_1fr] gap-8 items-start">
            <div class="space-y-5">
                <div class="rounded-3xl overflow-hidden border border-rose-100 shadow-xl bg-white">
                    <% if (home.photo) { %>
                        <img src="<%= home.photo %>" alt="<%= home.houseName %>" class="w-full h-[30rem] object-cover">
                    <% } else { %>
                        <div class="h-[30rem] flex items-center justify-center bg-gradient-to-br from-rose-100 to-orange-100 text-3xl font-semibold text-gray-500">No photo available</div>
                    <% } %>
                </div>

                <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                    <% for (let i = 0; i < 3; i++) { %>
                        <div class="gallery-tile rounded-2xl border border-rose-100 bg-white shadow-sm overflow-hidden">
                            <% if (home.photo) { %>
                                <img src="<%= home.photo %>" alt="<%= home.houseName %> gallery image" class="w-full h-full object-cover">
                            <% } else { %>
                                <div class="w-full h-full flex items-center justify-center bg-rose-50 text-sm text-gray-400">Gallery preview</div>
                            <% } %>
                        </div>
                    <% } %>
                </div>
            </div>

            <div class="bg-white rounded-3xl border border-rose-100 shadow-xl p-8 space-y-6 sticky top-6">
                <div class="flex items-center justify-between gap-4">
                    <div>
                        <p class="text-sm text-rose-400 font-medium mb-1"><%= home.homeType || 'Stay' %></p>
                        <h1 class="text-4xl font-semibold text-gray-800"><%= home.houseName %></h1>
                        <p class="text-gray-400 mt-2"><%= home.location %></p>
                    </div>
                    <div class="flex flex-col items-end gap-3">
                        <span class="<%= home.availability === 'available' ? 'bg-rose-50 text-rose-400' : 'bg-gray-100 text-gray-500' %> text-xs px-3 py-1.5 rounded-full">
                            <%= home.availability === 'available' ? 'Available' : 'Unavailable' %>
                        </span>
                        <% if (!isHostUser) { %>
                        <button
                            id="detailWishlistButton"
                            class="wishlist-btn <%= home.isFavourite ? 'active' : '' %> flex items-center gap-2 px-4 py-2 rounded-full border border-rose-100 text-sm font-medium text-gray-600 bg-white"
                            data-home-id="<%= home.id %>"
                            data-is-favourite="<%= home.isFavourite ? 'true' : 'false' %>"
                            aria-label="Toggle favourite"
                        >
                            <span id="detailWishlistIcon"><%= home.isFavourite ? '♥' : '♡' %></span>
                            <span id="detailWishlistLabel"><%= home.isFavourite ? 'Wishlisted' : 'Add to wishlist' %></span>
                        </button>
                        <% } %>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4 text-sm">
                    <div class="rounded-2xl bg-rose-50 px-4 py-3">
                        <p class="text-gray-400">Price</p>
                        <p class="text-gray-800 font-medium"><%= home.price ? `Rs ${home.price} / night` : 'Not set' %></p>
                    </div>
                    <div class="rounded-2xl bg-rose-50 px-4 py-3">
                        <p class="text-gray-400">Rating</p>
                        <p class="text-gray-800 font-medium"><%= home.rating || 0 %> / 5</p>
                    </div>
                    <div class="rounded-2xl bg-rose-50 px-4 py-3">
                        <p class="text-gray-400">Guests</p>
                        <p class="text-gray-800 font-medium">Up to <%= home.maxGuests %></p>
                    </div>
                    <div class="rounded-2xl bg-rose-50 px-4 py-3">
                        <p class="text-gray-400"><%= isHostUser ? 'Hosting view' : 'Wishlist' %></p>
                        <p id="wishlistStatusText" class="text-gray-800 font-medium"><%= isHostUser ? 'Favourites are available for guests only' : (home.isFavourite ? 'Saved in favourites' : 'Not saved yet') %></p>
                    </div>
                </div>

                <div class="rounded-3xl bg-rose-50 px-5 py-5">
                    <p class="text-sm font-medium text-gray-700 mb-2">About this home</p>
                    <p class="text-sm text-gray-500 leading-6">
                        <%= home.houseName %> is a <%= (home.homeType || 'stay').toLowerCase() %> in <%= home.location %> designed for up to <%= home.maxGuests %> guests.
                        <% if (home.price) { %>
                            It is currently listed at Rs <%= home.price %> per night
                        <% } else { %>
                            Pricing has not been finalized yet
                        <% } %>
                        and carries a rating of <%= home.rating || 0 %> out of 5.
                    </p>
                </div>

                <div class="flex flex-col sm:flex-row gap-3">
                    <a href="/reserve/<%= home.id %>" class="bg-rose-500 hover:bg-rose-600 text-white text-sm font-medium px-6 py-3 rounded-xl text-center shadow-md">
                        Book This Home
                    </a>
                    <% if (!isHostUser) { %>
                        <a href="/favourites" class="bg-white hover:bg-rose-50 text-rose-500 text-sm font-medium px-6 py-3 rounded-xl text-center border border-rose-200">
                            Open Wishlist
                        </a>
                    <% } else { %>
                        <a href="/" class="bg-white hover:bg-rose-50 text-rose-500 text-sm font-medium px-6 py-3 rounded-xl text-center border border-rose-200">
                            Back to Listings
                        </a>
                    <% } %>
                </div>

                <% if (currentUser && currentUser.userType === 'host') { %>
                    <a href="/host/edit-home/<%= home.id %>" class="block text-center text-sm text-gray-400 hover:text-rose-500 transition-colors">
                        Open Host Edit View
                    </a>
                <% } %>
            </div>
        </div>
    </main>
    <script>
        const wishlistButton = document.getElementById('detailWishlistButton');

        if (wishlistButton) {
            wishlistButton.addEventListener('click', async () => {
                const currentState = wishlistButton.dataset.isFavourite === 'true';
                const nextState = !currentState;
                const homeId = wishlistButton.dataset.homeId;

                try {
                    const response = await fetch(`/favourites/${homeId}`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({ isFavourite: nextState }),
                    });

                    if (!response.ok) {
                        if (response.status === 401) {
                            const result = await response.json();
                            window.location.href = result.redirectTo || '/login';
                            return;
                        }
                        throw new Error('Could not update favourite status.');
                    }

                    wishlistButton.dataset.isFavourite = String(nextState);
                    wishlistButton.classList.toggle('active', nextState);
                    document.getElementById('detailWishlistIcon').textContent = nextState ? '♥' : '♡';
                    document.getElementById('detailWishlistLabel').textContent = nextState ? 'Wishlisted' : 'Add to wishlist';
                    document.getElementById('wishlistStatusText').textContent = nextState ? 'Saved in favourites' : 'Not saved yet';
                } catch (error) {
                    alert('Could not update favourite. Please try again.');
                }
            });
        }
    </script>
</body>
</html>
