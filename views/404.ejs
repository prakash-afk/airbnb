<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 — Page Not Found</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'DM Sans', sans-serif; }
        .brand { font-family: 'Pacifico', cursive; }

        .fade-up { animation: fadeUp 0.6s ease both; }
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(24px); }
            to   { opacity: 1; transform: none; }
        }

        .float {
            animation: floating 3s ease-in-out infinite;
        }
        @keyframes floating {
            0%, 100% { transform: translateY(0px); }
            50%       { transform: translateY(-12px); }
        }

        .btn {
            transition: transform 0.15s ease, box-shadow 0.2s ease;
        }
        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(244,63,94,0.35);
        }
        .btn:active { transform: scale(0.97); }

        .four-o-four {
            font-size: 9rem;
            font-weight: 600;
            line-height: 1;
            background: linear-gradient(135deg, #f43f5e, #fb923c);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
    </style>
</head>
<body class="bg-rose-50 min-h-screen flex flex-col">

    <%# Navbar %>
    <header class="bg-white border-b border-rose-100 sticky top-0 z-10 shadow-sm">
        <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
            <a href="/" class="brand text-rose-500 text-2xl">airbnb</a>
            <a href="/" class="text-sm text-gray-400 hover:text-rose-400 transition-colors">← Back to listings</a>
        </div>
    </header>

    <%# 404 Content %>
    <main class="flex-1 flex items-center justify-center px-4 py-16">
        <div class="text-center max-w-md">

            <%# Floating house emoji %>
            <div class="float text-7xl mb-4">🏚️</div>

            <%# 404 number %>
            <div class="four-o-four fade-up" style="animation-delay: 0.1s">404</div>

            <%# Message %>
            <h1 class="text-2xl font-semibold text-gray-800 mt-4 fade-up" style="animation-delay: 0.2s">
                This place doesn't exist
            </h1>
            <p class="text-gray-400 text-sm mt-2 mb-8 fade-up" style="animation-delay: 0.3s">
                The page you're looking for may have been moved, deleted, or never existed in the first place.
            </p>

            <%# Actions %>
            <div class="flex flex-col sm:flex-row gap-3 justify-center fade-up" style="animation-delay: 0.4s">
                <a href="/"
                   class="btn bg-rose-500 hover:bg-rose-600 text-white font-medium px-6 py-3 rounded-full text-sm shadow-md">
                    Browse Listings
                </a>
                <a href="/host/add-home"
                   class="btn bg-white hover:bg-rose-50 text-rose-500 font-medium px-6 py-3 rounded-full text-sm border border-rose-200">
                    Add Your Home
                </a>
            </div>

            <%# Fun suggestion %>
            <p class="text-xs text-gray-300 mt-10 fade-up" style="animation-delay: 0.5s">
                Lost? Maybe it's time to list your own place instead. 🏠
            </p>

        </div>
    </main>

</body>
</html>
